{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/stefan/Code/JiraMaster/.claude/hooks/auto-commit.sh",
            "timeout": 30,
            "statusMessage": "Bumping patch version and committing..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python -m pytest*)",
      "Bash(python -m flake8*)",
      "Bash(python -m mypy*)",
      "Bash(pip install*)",
      "Bash(venv/bin/pip install*)",
      "Bash(venv/bin/python*)",
      "Bash(python app.py*)",
      "Bash(python3 app.py*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(~/.ssh/*)",
      "Read(config.json)",
      "Bash(rm -rf*)",
      "Bash(sudo*)"
    ]
  }
}
